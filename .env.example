# ServerMe — environment template (committable; copy to .env and fill in)
# Mirror of every value the prod systemd unit reads. Run install.sh after
# filling these in (script reads matching --flag args).

# ─── Domain / TLS ──────────────────────────────────────────────────────
DOMAIN=example.com
ACME_EMAIL=you@example.com
TLS_CERT=/etc/letsencrypt/live/example.com/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/example.com/privkey.pem
FRONTEND_URL=https://example.com

# ─── VPS access (only used by deploy scripts on your laptop) ──────────
VPS_HOST=
VPS_USER=root
VPS_PASS=

# ─── Server bind addresses ────────────────────────────────────────────
SERVER_ADDR=:8443
HTTP_ADDR=:9080
API_ADDR=:9081

# ─── Postgres ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://serverme:CHANGEME@localhost:5432/serverme?sslmode=disable
DB_USER=serverme
DB_PASS=CHANGEME
DB_NAME=serverme
DB_HOST=localhost
DB_PORT=5432

# ─── Auth (generate with `openssl rand -hex 32`) ──────────────────────
JWT_SECRET=
AUTH_TOKEN=disabled-use-api-keys

# ─── Google OAuth ─────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub App ───────────────────────────────────────────────────────
# Create at https://github.com/settings/apps/new
# Webhook URL: https://api.<your-domain>/api/v1/github/webhook
# Permissions: Contents (Read), Metadata (Read), Pull requests (Write), Webhooks (Read)
# Events: push, pull_request, installation
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_PRIVATE_KEY_PATH=/opt/serverme/github-app.pem

# ─── InventPay (optional — billing) ──────────────────────────────────
INVENTPAY_KEY=
INVENTPAY_WEBHOOK_SECRET=

# ─── Telegram (optional — notifications) ─────────────────────────────
TELEGRAM_TOKEN=

# ─── Cloudflare R2 / S3-compatible — off-site backups (optional) ─────
# After filling these, on the VPS run:
#   rclone config create r2 s3 provider Cloudflare \
#     access_key_id $R2_ACCESS_KEY secret_access_key $R2_SECRET_ACCESS_KEY \
#     endpoint $R2_ENDPOINT no_check_bucket true
# Then write `REMOTE=r2:$R2_BUCKET` to /etc/serverme/backup-remote.env
R2_BUCKET=serverme-backups
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_REMOTE_NAME=r2:serverme-backups

# ─── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
